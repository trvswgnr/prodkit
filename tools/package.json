{
  "name": "@prodkit/tools",
  "private": true,
  "description": "Maintainer tooling for the prodkit monorepo",
  "type": "module",
  "scripts": {
    "examples:smoke:pack": "node ./run-examples-smoke.ts pack",
    "examples:smoke:github": "node ./run-examples-smoke.ts github",
    "examples:smoke:npm": "node ./run-examples-smoke.ts npm",
    "examples:smoke:all": "pnpm run examples:smoke:pack && pnpm run examples:smoke:github && pnpm run examples:smoke:npm",
    "runtime:smoke": "node ./run-runtime-smoke.ts all",
    "runtime:smoke:bun": "node ./run-runtime-smoke.ts bun",
    "runtime:smoke:deno": "node ./run-runtime-smoke.ts deno",
    "runtime:smoke:edge": "node ./run-runtime-smoke.ts edge",
    "smoke": "pnpm run examples:smoke:pack",
    "performance:sync": "node ./update-op-performance-doc.ts",
    "adr:check": "node ./sync-adr-index.ts",
    "changelog:api:check": "node ./check-changelog-api.ts",
    "adr:sync": "node ./sync-adr-index.ts --write",
    "fmt": "oxfmt \"**/*.ts\"",
    "fmt:check": "oxfmt --check \"**/*.ts\"",
    "lint": "oxlint --config ../oxlint.config.ts .",
    "lint:fix": "oxlint --config ../oxlint.config.ts --fix .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prodkit/op": "workspace:*",
    "better-result": "2.9.0",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "miniflare": "^4.20260511.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
