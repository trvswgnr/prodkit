{
  "name": "@prodkit/monorepo",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "type": "module",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.11.0 <11"
  },
  "scripts": {
    "build": "turbo run build --log-order=grouped",
    "test": "turbo run test --log-order=grouped",
    "typecheck": "turbo run typecheck --log-order=grouped",
    "lint": "turbo run lint --log-order=grouped",
    "fmt": "turbo run fmt --log-order=grouped",
    "fmt:check": "turbo run fmt:check --log-order=grouped",
    "gate": "turbo run build typecheck test lint fmt:check --log-order=grouped && pnpm --filter @prodkit/tools run adr:check && pnpm --filter @prodkit/tools run changelog:api:check && pnpm --filter @prodkit/std run coverage && turbo run smoke --filter=@prodkit/tools --log-order=grouped",
    "bench": "turbo run codspeed:bench --filter=@prodkit/benchmarks --log-order=grouped",
    "build:size": "pnpm --filter @prodkit/op run build:size",
    "clean": "git clean -Xfd"
  },
  "devDependencies": {
    "oxlint": "catalog:",
    "turbo": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "tsdown>unrun": "0.3.0"
    }
  }
}
