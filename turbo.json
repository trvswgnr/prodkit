{
  "$schema": "https://turborepo.dev/schema.json",
  "envMode": "loose",
  "noUpdateNotifier": true,
  "globalDependencies": ["oxlint.config.ts"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json",
        "$TURBO_ROOT$/packages/shared/runtime/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.d.ts",
        "$TURBO_ROOT$/packages/shared/config/tsconfig.publishable.json",
        "$TURBO_ROOT$/packages/shared/config/tsdown.publishable.ts"
      ],
      "outputLogs": "new-only"
    },
    "@prodkit/shared#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "runtime/**/*.ts",
        "types/**/*.ts",
        "types/**/*.d.ts",
        "config/**/*.ts",
        "config/**/*.json",
        "tsconfig.json",
        "package.json"
      ],
      "outputLogs": "new-only"
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "inputs": [
        "**/*.ts",
        "vitest.config.ts",
        "tsconfig.json",
        "package.json",
        "$TURBO_ROOT$/packages/shared/runtime/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.d.ts",
        "$TURBO_ROOT$/packages/shared/config/tsconfig.publishable.json",
        "$TURBO_ROOT$/packages/shared/config/vitest.publishable.ts"
      ],
      "outputLogs": "new-only"
    },
    "@prodkit/benchmarks#test": {
      "dependsOn": ["@prodkit/op-lint#test", "^build", "build"],
      "inputs": [
        "**/*.ts",
        "vitest.config.ts",
        "tsconfig.json",
        "package.json",
        "$TURBO_ROOT$/packages/shared/runtime/**/*.ts"
      ],
      "outputLogs": "new-only"
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "**/*.ts",
        "tsconfig.json",
        "$TURBO_ROOT$/packages/shared/runtime/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.d.ts",
        "$TURBO_ROOT$/packages/shared/config/tsconfig.publishable.json"
      ],
      "outputLogs": "new-only"
    },
    "@prodkit/benchmarks#typecheck": {
      "dependsOn": ["@prodkit/op-lint#test", "^build"],
      "inputs": [
        "**/*.ts",
        "tsconfig.json",
        "$TURBO_ROOT$/packages/shared/runtime/**/*.ts"
      ],
      "outputLogs": "new-only"
    },
    "lint": {
      "inputs": [
        "**/*.ts",
        "tsconfig.json",
        "package.json",
        "$TURBO_ROOT$/packages/shared/runtime/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.d.ts"
      ],
      "outputLogs": "new-only"
    },
    "fmt": {
      "cache": false,
      "outputLogs": "new-only"
    },
    "fmt:check": {
      "inputs": [
        "**/*.ts",
        "$TURBO_ROOT$/packages/shared/runtime/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.ts",
        "$TURBO_ROOT$/packages/shared/types/**/*.d.ts",
        "$TURBO_ROOT$/packages/shared/config/**/*.ts"
      ],
      "outputLogs": "new-only"
    },
    "smoke": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputLogs": "new-only"
    },
    "codspeed:bench": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputLogs": "new-only"
    }
  }
}
