{
  "$schema": "https://turborepo.dev/schema.json",
  "envMode": "loose",
  "noUpdateNotifier": true,
  "globalDependencies": ["oxlint.config.ts"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**/*.ts", "tsdown.config.ts", "tsconfig.json", "package.json"],
      "outputLogs": "new-only"
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "inputs": ["**/*.ts", "vitest.config.ts", "tsconfig.json", "package.json"],
      "outputLogs": "new-only"
    },
    "@prodkit/benchmarks#test": {
      "dependsOn": ["@prodkit/op-lint#test", "^build", "build"],
      "inputs": ["**/*.ts", "vitest.config.ts", "tsconfig.json", "package.json"],
      "outputLogs": "new-only"
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "tsconfig.json"],
      "outputLogs": "new-only"
    },
    "@prodkit/benchmarks#typecheck": {
      "dependsOn": ["@prodkit/op-lint#test", "^build"],
      "inputs": ["**/*.ts", "tsconfig.json"],
      "outputLogs": "new-only"
    },
    "lint": {
      "inputs": ["**/*.ts", "tsconfig.json", "package.json"],
      "outputLogs": "new-only"
    },
    "fmt": {
      "cache": false,
      "outputLogs": "new-only"
    },
    "fmt:check": {
      "inputs": ["**/*.ts"],
      "outputLogs": "new-only"
    },
    "smoke": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputLogs": "new-only"
    },
    "codspeed:bench": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputLogs": "new-only"
    }
  }
}
