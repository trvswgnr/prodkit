{
  "$schema": "https://turborepo.dev/schema.json",
  "envMode": "loose",
  "globalDependencies": ["oxlint.config.ts"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**/*.ts", "tsdown.config.ts", "tsconfig.json", "package.json"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "inputs": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "**/*.ts",
        "vitest.config.ts",
        "tsconfig.json",
        "package.json"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "**/*.ts", "tsconfig.json"]
    },
    "lint": {
      "inputs": ["src/**/*.ts", "*.ts", "tsconfig.json", "package.json"]
    },
    "fmt": {
      "cache": false
    },
    "fmt:check": {
      "inputs": ["src/**/*.ts", "**/*.ts"]
    },
    "smoke": {
      "dependsOn": ["build", "^build"],
      "cache": false
    },
    "bench": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
