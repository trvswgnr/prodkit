{
  "name": "@prodkit/shared",
  "private": true,
  "version": "0.0.0",
  "description": "Private workspace-only shared types, config, and runtime primitives for @prodkit packages.",
  "type": "module",
  "types": "types/platform-globals.d.ts",
  "exports": {
    ".": {
      "types": "./types/platform-globals.d.ts"
    },
    "./platform-globals": "./types/platform-globals.d.ts",
    "./types/utils": {
      "types": "./types/utils.ts",
      "import": "./types/utils.ts"
    },
    "./runtime": {
      "types": "./runtime/index.ts",
      "import": "./runtime/index.ts"
    },
    "./tsconfig/publishable": "./config/tsconfig.publishable.json",
    "./vitest/publishable": "./config/vitest.publishable.ts",
    "./tsdown/publishable": "./config/tsdown.publishable.ts"
  },
  "scripts": {
    "fmt": "oxfmt \"types/**/*.ts\" \"runtime/**/*.ts\" \"config/**/*.ts\" \"types/**/*.d.ts\"",
    "fmt:check": "oxfmt --check \"types/**/*.ts\" \"runtime/**/*.ts\" \"config/**/*.ts\" \"types/**/*.d.ts\"",
    "lint": "pnpm -w exec oxlint --config oxlint.config.ts packages/shared",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
