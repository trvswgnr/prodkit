{
  "name": "@prodkit/std",
  "version": "0.1.0",
  "description": "Standard library utilities for @prodkit/op programs.",
  "keywords": [
    "dependency injection",
    "effect",
    "operations",
    "runtime-agnostic",
    "typescript"
  ],
  "homepage": "https://github.com/trvswgnr/prodkit#readme",
  "bugs": {
    "url": "https://github.com/trvswgnr/prodkit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trvswgnr/prodkit"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./di": {
      "types": "./dist/di/index.d.mts",
      "import": "./dist/di/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "fix": "pnpm run lint:fix && pnpm run fmt",
    "fmt": "oxfmt \"src/**/*.ts\" \"*.ts\"",
    "fmt:check": "oxfmt --check \"src/**/*.ts\" \"*.ts\"",
    "lint": "oxlint --config ../../oxlint.config.ts",
    "lint:fix": "oxlint --config ../../oxlint.config.ts --fix",
    "changelog:check": "node ../../tools/check-changelog-version.ts std",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm -C ../.. run gate && pnpm run changelog:check",
    "release:prepare": "pnpm -C ../.. run gate && pnpm run changelog:check && npm pack --dry-run",
    "release:patch": "node ../../tools/release-cut.ts std patch",
    "release:publish:manual": "npm publish --access public --provenance",
    "release:push": "git push && git push --tags",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@prodkit/op": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@prodkit/op": "^0.1.0",
    "better-result": "^2.9.0"
  }
}
