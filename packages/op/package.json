{
  "name": "@prodkit/op",
  "version": "0.1.75",
  "description": "A runtime-agnostic, composable library for writing predictable operations in TypeScript.",
  "keywords": [
    "composition",
    "effect",
    "error handling",
    "operations",
    "runtime-agnostic",
    "typescript"
  ],
  "homepage": "https://github.com/trvswgnr/prodkit#readme",
  "bugs": {
    "url": "https://github.com/trvswgnr/prodkit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trvswgnr/prodkit"
  },
  "files": [
    "dist",
    "COMPARISON.md",
    "DESIGN.md",
    "CHANGELOG.md",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./di": {
      "types": "./dist/di/index.d.mts",
      "import": "./dist/di/index.mjs"
    },
    "./hkt": {
      "types": "./dist/hkt.d.mts",
      "import": "./dist/hkt.mjs"
    },
    "./internal": {
      "types": "./dist/internal/index.d.mts",
      "import": "./dist/internal/index.mjs"
    },
    "./policy": {
      "types": "./dist/policy/index.d.mts",
      "import": "./dist/policy/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:size": "pnpm run build && esbuild dist/index.mjs --minify --target=es2022 --format=esm --outfile=dist/index.min.mjs",
    "changelog:check": "node ../../tools/check-changelog-version.ts op",
    "fix": "pnpm run lint:fix && pnpm run fmt",
    "fmt": "oxfmt \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\"",
    "fmt:check": "oxfmt --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\"",
    "lint": "oxlint --config ../../oxlint.config.ts",
    "lint:fix": "oxlint --config ../../oxlint.config.ts --fix",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm -C ../.. run gate && pnpm run changelog:check",
    "release:prepare": "pnpm -C ../.. run gate && pnpm run changelog:check && npm pack --dry-run",
    "release:patch": "node ../../tools/release-cut.ts op patch",
    "release:publish:manual": "npm publish --access public --provenance",
    "release:push": "git push && git push --tags",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@prodkit/shared": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "^0.25.11",
    "fast-check": "4.7.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unrun": "0.3.0",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "better-result": "^2.9.0"
  }
}
