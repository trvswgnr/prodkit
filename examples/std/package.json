{
  "name": "@prodkit/std-examples",
  "private": true,
  "description": "Consumer-level examples for @prodkit/std.",
  "type": "module",
  "scripts": {
    "gate": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check && pnpm run smoke",
    "fmt": "oxfmt \"**/*.ts\"",
    "fmt:check": "oxfmt --check \"**/*.ts\"",
    "lint": "oxlint --config ../../oxlint.config.ts .",
    "lint:fix": "oxlint --config ../../oxlint.config.ts --fix .",
    "smoke": "node ./smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prodkit/std": "workspace:*",
    "@prodkit/op": "workspace:*",
    "better-result": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
