{
  "name": "@prodkit/examples",
  "private": true,
  "description": "Consumer-level smoke checks and runnable examples for @prodkit/op (including @prodkit/op/di).",
  "type": "module",
  "scripts": {
    "fmt": "oxfmt \"**/*.ts\"",
    "fmt:check": "oxfmt --check \"**/*.ts\"",
    "lint": "pnpm -w exec oxlint --config oxlint.config.ts examples",
    "lint:fix": "pnpm -w exec oxlint --config oxlint.config.ts --fix examples",
    "smoke": "node ./smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prodkit/op": "workspace:*",
    "better-result": "2.9.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
