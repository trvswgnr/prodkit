{
  "name": "@prodkit/op-benchmarks",
  "private": true,
  "description": "Benchmark harness for @prodkit/op",
  "type": "module",
  "scripts": {
    "bench": "node ./bench.ts",
    "gate": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check",
    "fmt": "oxfmt \"**/*.ts\"",
    "fmt:check": "oxfmt --check \"**/*.ts\"",
    "lint": "oxlint --config ../../oxlint.config.ts .",
    "lint:fix": "oxlint --config ../../oxlint.config.ts --fix .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "esbuild": "^0.25.11",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tinybench": "^5.1.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
