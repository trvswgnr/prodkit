{
  "name": "@prodkit/op-benchmarks",
  "private": true,
  "description": "Benchmark harness for @prodkit/op",
  "type": "module",
  "scripts": {
    "codspeed:bench": "vitest bench --run",
    "profile": "node ./profile.ts",
    "profile:cpu": "node --cpu-prof --cpu-prof-interval=100 ./profile.ts --profile-mode=cpu",
    "profile:heap": "node --heap-prof ./profile.ts --profile-mode=heap",
    "test": "vitest run",
    "fmt": "oxfmt \"**/*.ts\"",
    "fmt:check": "oxfmt --check \"**/*.ts\"",
    "lint": "oxlint --config ../../oxlint.config.ts .",
    "lint:fix": "oxlint --config ../../oxlint.config.ts --fix .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "^5.0.1",
    "@prodkit/op": "workspace:*",
    "@types/node": "^24.12.2",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tinybench": "^5.1.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
